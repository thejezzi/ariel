{
  "name": "docs-renderer",
  "version": "0.1.0",
  "description": "Local documentation renderer for Markdown and MDX docs folders",
  "type": "module",
  "bin": {
    "docs-renderer": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts .",
    "build:client:css": "tailwindcss -i ./src/client/styles.css -o ./dist/client/styles.css --minify",
    "build": "npm run clean && tsc -p tsconfig.json && mkdir -p dist/client && npm run build:client:css && cp src/client/index.html dist/client/index.html && cp src/client/app.js dist/client/app.js && chmod +x dist/cli.js",
    "prepare": "npm run build",
    "clean": "rm -rf dist coverage .tmp-test-docs .tmp-test-docs-resolve",
    "test": "vitest run",
    "start": "node dist/cli.js .",
    "mcp:playwright": "playwright-mcp --headless --port 8931 --browser chrome --caps vision --output-mode stdout"
  },
  "keywords": [
    "docs",
    "markdown",
    "mdx",
    "mermaid",
    "cli"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "commander": "^14.0.0",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "open": "^10.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.76",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "playwright": "^1.61.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
